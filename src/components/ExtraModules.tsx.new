            <span className="text-[9px] text-[#718096]">Win Rate</span>
            <span className="text-xs font-extrabold text-[#E2E8F0] mt-0.5 block">{stats.winRate}</span>
          </div>
          <div className="bg-[#0B0A11] border border-white/10 rounded-[20px] p-2 shadow-[0_8px_32px_rgba(110,50,200,0.2)]">
            <span className="text-[9px] text-[#718096]">Profit Factor</span>
            <span className="text-xs font-extrabold text-[#E2E8F0] mt-0.5 block">{stats.profitFactor}</span>
          </div>
          <div className="bg-[#0B0A11] border border-white/10 rounded-[20px] p-2 shadow-[0_8px_32px_rgba(110,50,200,0.2)]">
            <span className="text-[9px] text-[#718096]">Sharpe Ratio</span>
            <span className="text-xs font-extrabold text-[#FF8A65] mt-0.5 block">{stats.sharpe}</span>
