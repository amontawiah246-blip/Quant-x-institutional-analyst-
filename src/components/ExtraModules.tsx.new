      </div>

      {isRunning ? (
        <div className="h-32 bg-[#0B0A11] border border-white/10 rounded-[20px] flex flex-col items-center justify-center gap-2.5 ">
          <div className="w-7 h-7 border-2 border-orange-500 border-t-transparent rounded-full animate-spin" />
          <span className="text-[10px] font-mono text-[#FF8A65] animate-pulse uppercase tracking-wider font-bold">Simulating 1,500 candles...</span>
        </div>
      ) : stats ? (
        <div className="grid grid-cols-3 gap-2.5 font-mono text-center">
          <div className="bg-[#0B0A11] border border-white/10 rounded-[20px] p-2 shadow-[0_8px_32px_rgba(110,50,200,0.2)]">
            <span className="text-[9px] text-[#718096]">Net Profit</span>
            <span className="text-xs font-extrabold text-[#00FF00] mt-0.5 block">{stats.pnl}</span>
          </div>
