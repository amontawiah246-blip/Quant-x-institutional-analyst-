        </div>
        <span className="text-[9px] font-mono bg-[#8A2BE2]/20 backdrop-blur-md text-orange-700 px-2 py-0.5 rounded border border-[#8A2BE2] shadow-[0_0_15px_rgba(138,43,226,0.5)] uppercase font-bold">Historical Simulation</span>
      </div>

      <div className="flex gap-2 mb-4">
        <select 
          value={selectedStrategy}
          onChange={(e) => setSelectedStrategy(e.target.value)}
          className="flex-1 bg-[#0B0A11] border border-white/10 rounded-[20px] p-2 text-xs text-slate-700 outline-none font-mono cursor-pointer"
        >
          <option>Smart Money (SMC)</option>
          <option>Order Block Mitigation</option>
          <option>Fair Value Gap (FVG) Reversal</option>
          <option>Wyckoff Spring Accumulation</option>
        </select>
        <button 
          onClick={triggerBacktest}
          disabled={isRunning}
          className="px-4.5 bg-[#8A2BE2]/20 backdrop-blur-md0 hover:bg-orange-600 disabled:opacity-50 text-white rounded-[20px] font-mono text-xs font-black tracking-wider uppercase flex items-center gap-1.5 cursor-pointer transition-colors"
        >
          <Play className="w-3.5 h-3.5" /> Backtest
